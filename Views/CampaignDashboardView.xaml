<UserControl x:Class="FateDefiner.Views.CampaignDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Campaign Dashboard" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Create, load, and manage your campaigns"
                       Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
        </StackPanel>

        <!-- Two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: Campaign List ══ -->
            <Border Grid.Column="0" Style="{StaticResource CardPanelStyle}">
                <DockPanel>

                    <!-- New Campaign Input -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="CREATE NEW CAMPAIGN" Style="{StaticResource SectionLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewCampaignName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button  Grid.Column="2" Content="Create"
                                     Command="{Binding NewCampaignCommand}"
                                     Padding="10,8"/>
                        </Grid>
                    </StackPanel>

                    <Separator DockPanel.Dock="Top"/>

                    <TextBlock DockPanel.Dock="Top"
                               Text="MY CAMPAIGNS" Style="{StaticResource SectionLabelStyle}"
                               Margin="0,8,0,4"/>

                    <!-- Campaign list -->
                    <ListBox ItemsSource="{Binding Campaigns}"
                             SelectedItem="{Binding SelectedCampaign}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding Characters.Count, StringFormat={}{0} chars  ·  last modified }"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding LastModified, StringFormat={}{0:MMM d, yyyy}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>

            <!-- ══ RIGHT: Campaign Details ══ -->
            <Border Grid.Column="2" Style="{StaticResource CardPanelStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="CAMPAIGN DETAILS" Style="{StaticResource SectionLabelStyle}"/>

                        <!-- Empty state -->
                        <TextBlock TextWrapping="Wrap" Margin="0,12"
                                   Foreground="{StaticResource MutedTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCampaign}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            Select a campaign from the list, or create a new one above.
                        </TextBlock>

                        <!-- Details form (only when a campaign is selected) -->
                        <StackPanel DataContext="{Binding SelectedCampaign}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Campaign Name" Style="{StaticResource SectionLabelStyle}"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,14" FontSize="15" FontWeight="SemiBold"/>

                            <TextBlock Text="World / Setting" Style="{StaticResource SectionLabelStyle}"/>
                            <TextBox Text="{Binding Setting, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,14"/>

                            <TextBlock Text="Description" Style="{StaticResource SectionLabelStyle}"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     Height="90" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,16"/>

                            <!-- Stats row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Style="{StaticResource StatBoxStyle}" Width="Auto" Padding="10,7" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="CHARACTERS" Style="{StaticResource SectionLabelStyle}" FontSize="9"/>
                                        <TextBlock Text="{Binding Characters.Count}" FontSize="20"
                                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatBoxStyle}" Width="Auto" Padding="10,7" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="FACTIONS" Style="{StaticResource SectionLabelStyle}" FontSize="9"/>
                                        <TextBlock Text="{Binding Factions.Count}" FontSize="20"
                                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatBoxStyle}" Width="Auto" Padding="10,7">
                                    <StackPanel>
                                        <TextBlock Text="SESSION NOTES" Style="{StaticResource SectionLabelStyle}" FontSize="9"/>
                                        <TextBlock Text="{Binding SessionNotes.Count}" FontSize="20"
                                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Separator Margin="0,16"/>

                            <!-- Action buttons -->
                            <WrapPanel>
                                <Button Content="Open Campaign"
                                        Command="{Binding DataContext.OpenCampaignCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Save Changes"
                                        Command="{Binding DataContext.SaveCampaignCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteCampaignCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Margin="0,0,0,8"/>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Status message -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11" Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
