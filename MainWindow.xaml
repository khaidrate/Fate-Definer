<Window x:Class="FateDefiner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fate Definer — Tabletop RPG Campaign Manager"
        Height="820" Width="1260"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ SIDEBAR ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>

                <!-- App Brand Header -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="⚔" FontSize="36" HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}" Margin="0,22,0,4"/>
                    <TextBlock Text="FATE DEFINER" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Campaign Manager" FontSize="10"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,16"/>
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="16,0"/>
                </StackPanel>

                <!-- Active Campaign Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="ACTIVE CAMPAIGN" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding CampaignName}"
                                   FontSize="12" Margin="0,5,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Navigation Buttons -->
                <StackPanel Margin="8,16,8,0">

                    <TextBlock Text="CAMPAIGN" Style="{StaticResource SectionLabelStyle}"
                               Margin="12,0,0,4" FontSize="10"/>
                    <Button Content="&#x1F5FA;&#xFE0F;  Dashboard"
                            Command="{Binding GoToDashboardCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="&#x1F464;  Characters"
                            Command="{Binding GoToCharactersCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="&#x269C;  Factions &amp; NPCs"
                            Command="{Binding GoToFactionsCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="&#x1F4DC;  Session Notes"
                            Command="{Binding GoToNotesCommand}"
                            Style="{StaticResource NavButtonStyle}"/>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="8,10"/>

                    <TextBlock Text="TOOLS" Style="{StaticResource SectionLabelStyle}"
                               Margin="12,0,0,4" FontSize="10"/>
                    <Button Content="&#x1F3B2;  Dice Roller"
                            Command="{Binding GoToDiceCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="&#x2694;&#xFE0F;  Encounters &amp; Loot"
                            Command="{Binding GoToEncountersCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════ MAIN CONTENT AREA ═══════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content host: DataTemplate in App.xaml maps ViewModel → View -->
            <ContentControl Grid.Row="0"
                            Content="{Binding CurrentViewModel}"/>

            <!-- Status Bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,6">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
